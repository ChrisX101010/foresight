# ────────────────────────────────────────────────────────────────────────
# FORESIGHT — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# ────────────────────────────────────────────────────────────────────────

# ─── Solana RPC ──────────────────────────────────────────────────────────
# QuickNode endpoint strongly recommended (Kamino SDK issues many reads).
# Free tier signup: https://www.quicknode.com/endpoints
# Public mainnet-beta works for a demo but rate-limits fast.
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
NEXT_PUBLIC_SOLANA_NETWORK="mainnet-beta"

# ─── DFlow ───────────────────────────────────────────────────────────────
# Dev endpoints are key-less, rate-limited, mainnet-only. Good for dev/demo.
# Production: request key at https://pond.dflow.net/build/api-key
DFLOW_METADATA_BASE="https://dev-prediction-markets-api.dflow.net"
NEXT_PUBLIC_DFLOW_TRADE_BASE="https://dev-quote-api.dflow.net"
DFLOW_API_KEY=""

# ─── Kamino ──────────────────────────────────────────────────────────────
# Main market address (USDC, USDT, SOL, mSOL, etc.) from the Kamino docs:
# https://docs.kamino.finance/build-on-kamino/sdk-and-smart-contracts
NEXT_PUBLIC_KAMINO_MAIN_MARKET="7u3HeHxYDLhnCoErrtycNokbQYbWGzLs6JSDqGAv5PfF"

# ─── Eitherway attribution (required by bounty) ─────────────────────────
NEXT_PUBLIC_BUILT_WITH_EITHERWAY="true"
